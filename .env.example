# Telegram Bot Token
# Получите у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID
# ID канала или группы, куда бот будет отправлять уведомления
TELEGRAM_CHAT_ID=your_chat_id_here

# io.net API Key для Kimi K2
# API ключ для генерации комплексов упражнений
IO_NET_API_KEY=your_io_net_api_key_here

# Email для отправки PDF
# Gmail аккаунт для отправки писем
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
